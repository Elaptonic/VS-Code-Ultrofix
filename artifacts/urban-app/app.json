{
  "expo": {
    "name": "Ultrofix",
    "slug": "ultrofix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ultrofix",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#38BDF8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ultrofix.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "backgroundColor": "#38BDF8",
      "package": "com.ultrofix.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": { "useFrameworks": "static" }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Ultrofix needs your location to show customers your position while you're on a job.",
          "locationWhenInUsePermission": "Ultrofix needs your location to show customers your position while you're on a job."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}